{
  "name": "bathhub",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "node --experimental-strip-types scripts/validate-required-env.mts --dev && next dev",
    "build": "npm run build:user-settings-db && next build",
    "build:user-settings-db": "node integration-tests/run-build-default-user-settings-db.mjs",
    "start": "node --experimental-strip-types scripts/validate-required-env.mts && next start",
    "lint": "eslint",
    "unit-tests": "jest --verbose ./unit-tests",
    "integration-tests": "node integration-tests/run-docker.mjs"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "^3.50.4-build1",
    "@supabase/supabase-js": "^2.107.0",
    "cesium": "^1.141.0",
    "h3-js": "^4.5.0",
    "ioredis": "^5.11.1",
    "next": "^16.2.6",
    "openrouteservice-js": "^0.4.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.71.0",
    "@tailwindcss/postcss": "^4",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jest": "^30.4.2",
    "supabase": "^2.109.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
